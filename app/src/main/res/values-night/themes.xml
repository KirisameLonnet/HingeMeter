<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.HingeMeter" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/hinge_black</item>
        <item name="colorPrimaryVariant">@color/hinge_black</item>
        <item name="colorOnPrimary">@color/hinge_white</item>
        <item name="colorSecondary">@color/hinge_white</item>
        <item name="colorSecondaryVariant">@color/hinge_white</item>
        <item name="colorOnSecondary">@color/hinge_black</item>
        <item name="android:statusBarColor">@color/hinge_black</item>
        <item name="android:navigationBarColor">@color/hinge_black</item>
        <item name="android:windowBackground">@color/hinge_black</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
